// AI网文创作平台 - 数据库Schema (SQLite - 仅用于本地开发)
// 生产环境请使用 prisma/schema.prisma (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 项目管理 ====================

model NovelProject {
  id           String   @id @default(cuid())
  title        String
  description  String?
  genre        String?
  subGenre     String?
  coverImage   String?
  status       String    @default("draft")
  wordCount    Int       @default(0)
  targetWords  Int?
  setting      String?
  premise      String?
  writingStyle String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  characters      Character[]
  locations       Location[]
  loreItems       LoreItem[]
  factions        Faction[]
  outlines        Outline[]
  chapters        Chapter[]
  materials       Material[]
  snapshots       VersionSnapshot[]
  changes         ChangeProposal[]
  aiConversations AiConversation[]
}

// ==================== 世界观设定 (Story Bible) ====================

model Character {
  id            String   @id @default(cuid())
  projectId     String
  name          String
  role          String?
  title         String?
  age           String?
  gender        String?
  description   String?
  personality   String?
  background    String?
  abilities     String?
  relationships String?
  motivation    String?
  arc           String?
  tags          String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Location {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  category    String?
  description String?
  history     String?
  features    String?
  atmosphere  String?
  tags        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model LoreItem {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  category    String?
  description String?
  details     String?
  constraints String?
  tags        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Faction {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  goals       String?
  members     String?
  territory   String?
  power       String?
  tags        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ==================== 大纲系统 (Outline → Beats) ====================

model Outline {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  type        String   @default("act")
  description String?
  keyEvents   String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapters Chapter[]
}

// ==================== 章节与写作 ====================

model Chapter {
  id         String   @id @default(cuid())
  projectId  String
  outlineId  String?
  title      String
  summary    String?
  beats      String?
  content    String?
  wordCount  Int      @default(0)
  status     String   @default("planned")
  notes      String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project NovelProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outline Outline?      @relation(fields: [outlineId], references: [id], onDelete: SetNull)
  versions ChapterVersion[]
}

model ChapterVersion {
  id         String   @id @default(cuid())
  chapterId  String
  content    String
  wordCount  Int
  label      String?
  changeNote String?
  source     String   @default("manual")
  createdAt  DateTime @default(now())

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

// ==================== 素材库 ====================

model Material {
  id        String   @id @default(cuid())
  projectId String
  title     String
  category  String?
  content   String?
  source    String?
  tags      String?
  isGlobal  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ==================== 版本管理 (OpenSpec-inspired) ====================

model VersionSnapshot {
  id        String   @id @default(cuid())
  projectId String
  label     String
  type      String   @default("milestone")
  data      String
  note      String?
  createdAt DateTime @default(now())

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ChangeProposal {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  type        String    @default("revision")
  targetScope String?
  impact      String?
  plan        String?
  status      String    @default("proposed")
  appliedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ==================== AI对话记录 ====================

model AiConversation {
  id        String   @id @default(cuid())
  projectId String
  title     String?
  context   String?
  messages  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
