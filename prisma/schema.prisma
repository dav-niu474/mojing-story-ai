// AI网文创作平台 - 数据库Schema
// 灵感来源: Superpowers流程架构 + OpenSpec版本管理 + 市场主流产品

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 项目管理 ====================

model NovelProject {
  id          String   @id @default(cuid())
  title       String
  description String?
  genre       String?   // 玄幻、都市、仙侠、科幻、历史、游戏、悬疑等
  subGenre    String?   // 子类型
  coverImage  String?
  status      String    @default("draft") // draft, outlining, writing, revision, complete
  wordCount   Int       @default(0)
  targetWords Int?
  setting     String?   // 世界观概述
  premise     String?   // 核心设定/故事前提
  writingStyle String?  // 文风偏好
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  characters    Character[]
  locations     Location[]
  loreItems     LoreItem[]
  factions      Faction[]
  outlines      Outline[]
  chapters      Chapter[]
  materials     Material[]
  snapshots     VersionSnapshot[]
  changes       ChangeProposal[]
  aiConversations AiConversation[]
}

// ==================== 世界观设定 (Story Bible) ====================

model Character {
  id            String   @id @default(cuid())
  projectId     String
  name          String
  role          String?   // protagonist, antagonist, supporting, minor
  title         String?   // 称号/别名
  age           String?
  gender        String?
  description   String?   // 外貌描述
  personality   String?   // 性格特征
  background    String?   // 背景故事
  abilities     String?   // 能力/技能
  relationships String?   // 人物关系 (JSON)
  motivation    String?   // 动机/目标
  arc           String?   // 人物弧光
  tags          String?   // 标签 (逗号分隔)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Location {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  category    String?   // city, region, building, natural, other
  description String?
  history     String?
  features    String?   // 特色/规则
  atmosphere  String?   // 氛围
  tags        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model LoreItem {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  category    String?   // power-system, technology, culture, history, rules, items, organizations
  description String?
  details     String?   // 详细规则/机制
  constraints String?   // 限制/代价
  tags        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Faction {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  goals       String?   // 目标/宗旨
  members     String?   // 核心成员
  territory   String?   // 势力范围
  power       String?   // 实力评估
  tags        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ==================== 大纲系统 (Outline → Beats) ====================

model Outline {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  type        String   @default("act") // act, volume, arc
  description String?   // 本卷/幕概述
  keyEvents   String?   // 关键事件 (JSON数组)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapters Chapter[]
}

// ==================== 章节与写作 ====================

model Chapter {
  id          String   @id @default(cuid())
  projectId   String
  outlineId   String?
  title       String
  summary     String?   // 章节概要
  beats       String?   // 场景节拍 JSON: [{title, description, characters[], location, mood}]
  content     String?   // 正文内容
  wordCount   Int      @default(0)
  status      String   @default("planned") // planned, drafting, revision, complete
  notes       String?   // 写作笔记
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  NovelProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outline  Outline?      @relation(fields: [outlineId], references: [id], onDelete: SetNull)
  versions ChapterVersion[]
}

model ChapterVersion {
  id          String   @id @default(cuid())
  chapterId   String
  content     String
  wordCount   Int
  label       String?   // "初稿", "修订版1", "AI润色版" 等
  changeNote  String?   // 变更说明
  source      String   @default("manual") // manual, ai-generate, ai-polish, ai-expand
  createdAt   DateTime @default(now())

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

// ==================== 素材库 ====================

model Material {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  category    String?   // template, reference, inspiration, generator, name-dict, trope
  content     String?
  source      String?   // 来源
  tags        String?
  isGlobal    Boolean  @default(false) // 是否为全局素材
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ==================== 版本管理 (OpenSpec-inspired) ====================

model VersionSnapshot {
  id          String   @id @default(cuid())
  projectId   String
  label       String
  type        String   @default("milestone") // milestone, checkpoint, auto, pre-change
  data        String   // JSON: 序列化的项目状态快照
  note        String?
  createdAt   DateTime @default(now())

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ChangeProposal {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  type        String   @default("revision") // revision, addition, deletion, restructuring
  targetScope String?   // 影响范围 (JSON: 哪些角色/地点/剧情线)
  impact      String?   // 影响分析
  plan        String?   // 实施计划
  status      String   @default("proposed") // proposed, approved, in-progress, applied, rejected, archived
  appliedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ==================== AI对话记录 ====================

model AiConversation {
  id          String   @id @default(cuid())
  projectId   String
  title       String?
  context     String?   // 对话上下文类型 (world-building, outline, writing, review)
  messages    String    // JSON: 对话消息数组
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
