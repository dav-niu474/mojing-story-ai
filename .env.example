# ==========================================
# 墨境 AI网文创作平台 - 环境变量模板
# ==========================================
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
#
# ⚠️  .env 文件已被 .gitignore 排除，不会被提交到代码仓库
# ⚠️  绝对不要在代码中硬编码任何密钥！

# ---------- 数据库 ----------
# 本地开发 (SQLite):
DATABASE_URL=file:./db/custom.db

# Vercel 生产环境 (PostgreSQL / Neon):
# 在 Vercel 项目设置 → Environment Variables 中设置 DATABASE_URL
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ---------- AI 模型 ----------
# NVIDIA NIM API Key (从 https://build.nvidia.com/ 获取)
NVIDIA_API_KEY=nvapi-your-key-here
